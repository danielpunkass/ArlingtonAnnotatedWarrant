.DS_Store
.claude/

# Raw HTML snapshot the sync script writes for local diffing/debugging.
# index.json captures the structured data; the HTML is large and noisy.
# Remove this line if you want versioned snapshots of the upstream page.
source.html

# MkDocs build output.
site/

# pdf2htmlEX-generated renderings of the attachment PDFs. These are
# inlined into per-attachment pages by the sync script. They're ~5-10MB
# each (fonts embedded) and would push the repo near GitHub's 1GB soft
# limit; CI regenerates them from the source PDFs on each sync run.
articles/**/*.pdf.html

# Per-attachment markdown pages (articles/Article-N/<slug>/index.md).
# These are pure build artifacts: the sync script splices the inlined
# pdf2htmlEX HTML/CSS (with embedded WOFF fonts) into them, and that
# output is non-deterministic — committing them produced multi-MB diffs
# on every sync even when nothing upstream changed. The articles/.pages
# files (sidebar nav) and article-level index.md (Summary) are still
# tracked; only the per-attachment leaves are regenerated at build time.
articles/*/*/index.md

# Staging directory the deploy workflow populates with site-relevant files
# (articles, index.md derived from INDEX.md, index.json, CNAME) before
# running `mkdocs build`. Never committed.
_site_build/

# Python cruft.
__pycache__/
*.pyc
.venv/
